{
  "name": "odd1out-site",
  "version": "2.0.0",
  "description": "The home of Odd1Out on the web",
  "main": "index.html",
  "scripts": {
    "dev": "serve src",
    "test": "serve dist",
    "clean": "rm -rf dist",
    "build:html": "cp src/index.html dist",
    "build:css": "cp -r src/css/ dist/css",
    "build:fonts": "cp -r src/fonts/ dist/fonts",
    "build:img": "cp -r src/img/ dist/img",
    "build": "npm run clean && mkdir dist && npm run build:html && npm run build:css && npm run build:img && npm run build:fonts",
    "docker": "docker compose up -d --build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odd1outband/website.git"
  },
  "keywords": [
    "Band",
    "Rock",
    "Website"
  ],
  "author": "Martin Flodin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/odd1outband/website/issues"
  },
  "homepage": "https://odd1out.band",
  "devDependencies": {
    "serve": "^14.2.6"
  }
}
